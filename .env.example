# ── 基本設定 ────────────────────────────────────────────────
APP_NAME=新竹團購平台
DEBUG=false
SECRET_KEY=change-me-in-production-use-random-32-chars

# ── 資料庫 ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gbuser:gbpass@localhost:5432/groupbuy

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Firebase FCM（推播通知）──────────────────────────────────
# 下載 Firebase Admin SDK 金鑰後放在 backend/ 目錄下
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── SMS 驗證碼 ───────────────────────────────────────────────
# 選項：mock（開發用，不實際發送）| twilio | every8d
SMS_PROVIDER=mock

# Twilio（SMS_PROVIDER=twilio 時填寫）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX

# every8d（SMS_PROVIDER=every8d 時填寫）
EVERY8D_UID=
EVERY8D_PWD=

# ── 社群登入 ─────────────────────────────────────────────────
# Google OAuth2 用戶端 ID（前端 Google Sign-In 需要）
GOOGLE_CLIENT_ID=

# LINE Login Channel ID
LINE_CHANNEL_ID=

# Apple Sign-In App Bundle ID
APPLE_CLIENT_ID=

# ── 平台佣金 ─────────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.10
