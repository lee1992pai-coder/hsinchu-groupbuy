DATABASE_URL=postgresql+asyncpg://gbuser:gbpass@localhost:5432/groupbuy
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-super-secret-key-here

# ── SMS 簡訊 ──────────────────────────────────────────────
SMS_PROVIDER=mock      # mock | twilio | every8d
# Twilio（選填）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890
# 每8d（台灣，選填）
EVERY8D_UID=
EVERY8D_PWD=

# ── 社群登入 ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=       # Google Cloud Console OAuth 2.0
LINE_CHANNEL_ID=        # LINE Developers Console
APPLE_CLIENT_ID=        # Apple Developer Console

# ── 綠界 ECPay（付款功能後續接入）─────────────────────────
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_STAGE=true        # false = 正式環境

# ── Firebase（Push 推播）──────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── 平台設定 ─────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.10
